<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تطبيق أسعار صرف العملات العالمي</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #1a2a6c, #b21f1f, #1a2a6c);
            color: #fff;
            min-height: 100vh;
            padding: 20px;
            transition: background 0.5s ease;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding: 20px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            position: relative;
        }
        
        .header-content {
            flex: 1;
            text-align: center;
        }
        
        .settings-btn {
            background: rgba(255, 255, 255, 0.15);
            border: none;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        
        .settings-btn:hover {
            transform: rotate(30deg);
            background: rgba(255, 255, 255, 0.25);
        }
        
        h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            color: #FFD700;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
        }
        
        .subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            margin-bottom: 15px;
        }
        
        .date-display {
            font-size: 1.1rem;
            background: rgba(0, 0, 0, 0.2);
            padding: 10px 20px;
            border-radius: 30px;
            display: inline-block;
            margin-top: 10px;
        }
        
        .controls {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin: 25px 0;
            flex-wrap: wrap;
        }
        
        .base-currency {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 12px 20px;
            border-radius: 30px;
            font-size: 1rem;
            width: 250px;
            backdrop-filter: blur(10px);
        }
        
        .search-box {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 12px 20px;
            border-radius: 30px;
            font-size: 1rem;
            width: 350px;
            backdrop-filter: blur(10px);
        }
        
        .search-box::placeholder {
            color: rgba(255, 255, 255, 0.7);
        }
        
        .currency-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .currency-card {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 25px;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .currency-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
            background: rgba(255, 255, 255, 0.15);
        }
        
        .currency-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .currency-name {
            font-size: 1.5rem;
            font-weight: bold;
        }
        
        .currency-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.15);
            font-size: 1.5rem;
        }
        
        .currency-value {
            font-size: 2rem;
            font-weight: bold;
            margin: 10px 0;
            color: #FFD700;
        }
        
        .currency-change {
            display: flex;
            align-items: center;
            font-size: 1rem;
            margin-top: 10px;
        }
        
        .change-up {
            color: #4CAF50;
        }
        
        .change-down {
            color: #F44336;
        }
        
        .last-update {
            font-size: 0.9rem;
            opacity: 0.7;
            margin-top: auto;
            padding-top: 15px;
        }
        
        .loading {
            text-align: center;
            padding: 50px;
            font-size: 1.5rem;
            grid-column: 1 / -1;
        }
        
        .error {
            text-align: center;
            padding: 50px;
            font-size: 1.2rem;
            color: #ff6b6b;
            grid-column: 1 / -1;
        }
        
        .footer {
            text-align: center;
            margin-top: 40px;
            padding: 20px;
            font-size: 0.9rem;
            opacity: 0.8;
        }
        
        /* إعدادات اللغة */
        .settings-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            backdrop-filter: blur(5px);
            justify-content: center;
            align-items: center;
        }
        
        .settings-content {
            background: linear-gradient(135deg, #2c3e50, #1a2a6c);
            border-radius: 15px;
            width: 90%;
            max-width: 500px;
            padding: 30px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.5);
        }
        
        .settings-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .settings-title {
            font-size: 1.8rem;
            color: #FFD700;
        }
        
        .close-settings {
            background: none;
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            transition: transform 0.3s ease;
        }
        
        .close-settings:hover {
            transform: scale(1.2);
        }
        
        .language-section {
            margin-bottom: 30px;
        }
        
        .section-title {
            font-size: 1.2rem;
            margin-bottom: 15px;
            color: #FFD700;
        }
        
        .language-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 15px;
        }
        
        .language-option {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .language-option:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateY(-3px);
        }
        
        .language-option.selected {
            background: rgba(255, 215, 0, 0.2);
            border: 1px solid #FFD700;
        }
        
        .theme-section {
            margin-bottom: 30px;
        }
        
        .theme-options {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }
        
        .theme-option {
            flex: 1;
            min-width: 120px;
            padding: 15px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.15);
            cursor: pointer;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        .theme-option:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: translateY(-3px);
        }
        
        .theme-option.selected {
            background: rgba(255, 215, 0, 0.2);
            border: 1px solid #FFD700;
        }
        
        .theme-color {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            margin: 0 auto 10px;
        }
        
        .theme-1 { background: linear-gradient(135deg, #1a2a6c, #b21f1f); }
        .theme-2 { background: linear-gradient(135deg, #0f9b0f, #3a7bd5); }
        .theme-3 { background: linear-gradient(135deg, #7b4397, #dc2430); }
        .theme-4 { background: linear-gradient(135deg, #141E30, #243B55); }
        
        .save-settings {
            background: linear-gradient(to right, #FFD700, #FFA500);
            color: #1a2a6c;
            border: none;
            border-radius: 30px;
            padding: 15px 30px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s ease;
        }
        
        .save-settings:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(255, 215, 0, 0.4);
        }
        
        /* تحسينات للبحث */
        .search-container {
            position: relative;
            width: 350px;
        }
        
        .search-box {
            padding-left: 50px;
            width: 100%;
        }
        
        .search-icon {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.2rem;
            color: rgba(255, 255, 255, 0.7);
        }
        
        @media (max-width: 768px) {
            .currency-grid {
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            }
            
            h1 {
                font-size: 2rem;
            }
            
            .controls {
                flex-direction: column;
                align-items: center;
            }
            
            .search-container, .base-currency {
                width: 100%;
            }
            
            header {
                flex-direction: column;
                gap: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <button class="settings-btn" id="settingsBtn">
                <i class="fas fa-cog"></i>
            </button>
            
            <div class="header-content">
                <h1><i class="fas fa-coins"></i> أسعار صرف العملات العالمي</h1>
                <p class="subtitle">تطبيق متكامل لعرض أحدث أسعار الصرف العالمية</p>
                <div class="date-display" id="currentDate">جاري التحميل...</div>
            </div>
            
            <div style="width: 50px;"></div> <!-- عنصر فارغ للمحاذاة -->
        </header>
        
        <div class="controls">
            <select id="baseCurrency" class="base-currency">
                <option value="USD">العملة الأساسية: الدولار الأمريكي (USD)</option>
                <option value="EUR">اليورو (EUR)</option>
                <option value="EGP">الجنيه المصري (EGP)</option>
                <option value="SAR">الريال السعودي (SAR)</option>
                <option value="AED">درهم الإمارات (AED)</option>
            </select>
            
            <div class="search-container">
                <div class="search-icon">
                    <i class="fas fa-search"></i>
                </div>
                <input type="text" id="searchInput" class="search-box" placeholder="ابحث عن عملة...">
            </div>
        </div>
        
        <div class="currency-grid" id="currencyContainer">
            <div class="loading">
                <i class="fas fa-spinner fa-spin"></i> جاري تحميل بيانات أسعار الصرف...
            </div>
        </div>
        
        <div class="footer">
            <p>يتم تحديث الأسعار تلقائيًا يوميًا | آخر تحديث: <span id="lastUpdated"></span></p>
        </div>
    </div>

    <!-- إعدادات اللغة -->
    <div class="settings-modal" id="settingsModal">
        <div class="settings-content">
            <div class="settings-header">
                <h2 class="settings-title"><i class="fas fa-cog"></i> إعدادات التطبيق</h2>
                <button class="close-settings" id="closeSettings">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="language-section">
                <h3 class="section-title"><i class="fas fa-globe"></i> اللغة</h3>
                <div class="language-grid">
                    <div class="language-option selected" data-lang="ar">
                        العربية
                    </div>
                    <div class="language-option" data-lang="en">
                        English
                    </div>
                    <div class="language-option" data-lang="es">
                        Español
                    </div>
                    <div class="language-option" data-lang="fr">
                        Français
                    </div>
                    <div class="language-option" data-lang="de">
                        Deutsch
                    </div>
                    <div class="language-option" data-lang="zh">
                        中文 (الصينية)
                    </div>
                    <div class="language-option" data-lang="ru">
                        Русский (الروسية)
                    </div>
                    <div class="language-option" data-lang="pt">
                        Português
                    </div>
                    <div class="language-option" data-lang="ja">
                        日本語 (اليابانية)
                    </div>
                    <div class="language-option" data-lang="hi">
                        हिन्दी (الهندية)
                    </div>
                </div>
            </div>
            
            <div class="theme-section">
                <h3 class="section-title"><i class="fas fa-palette"></i> المظهر</h3>
                <div class="theme-options">
                    <div class="theme-option selected" data-theme="1">
                        <div class="theme-color theme-1"></div>
                        أساسي
                    </div>
                    <div class="theme-option" data-theme="2">
                        <div class="theme-color theme-2"></div>
                        أخضر/أزرق
                    </div>
                    <div class="theme-option" data-theme="3">
                        <div class="theme-color theme-3"></div>
                        أرجواني/أحمر
                    </div>
                    <div class="theme-option" data-theme="4">
                        <div class="theme-color theme-4"></div>
                        ليلي
                    </div>
                </div>
            </div>
            
            <button class="save-settings" id="saveSettings">
                حفظ الإعدادات
            </button>
        </div>
    </div>

    <script>
        // عناصر DOM
        const currencyContainer = document.getElementById('currencyContainer');
        const currentDateEl = document.getElementById('currentDate');
        const lastUpdatedEl = document.getElementById('lastUpdated');
        const searchInput = document.getElementById('searchInput');
        const baseCurrencySelect = document.getElementById('baseCurrency');
        const settingsBtn = document.getElementById('settingsBtn');
        const settingsModal = document.getElementById('settingsModal');
        const closeSettings = document.getElementById('closeSettings');
        const saveSettings = document.getElementById('saveSettings');
        const languageOptions = document.querySelectorAll('.language-option');
        const themeOptions = document.querySelectorAll('.theme-option');
        
        // العملات المطلوبة
        const targetCurrencies = [
            'USD', 'EUR', 'GBP', 'EGP', 'JPY', 
            'AUD', 'CAD', 'CHF', 'CNY', 'INR',
            'AED', 'SAR', 'TRY', 'RUB', 'BRL', 'KRW'
        ];
        
        // أسماء العملات
        const currencyNames = {
            USD: 'الدولار الأمريكي',
            EUR: 'اليورو',
            GBP: 'الجنيه الإسترليني',
            EGP: 'الجنيه المصري',
            JPY: 'الين الياباني',
            AUD: 'الدولار الأسترالي',
            CAD: 'الدولار الكندي',
            CHF: 'الفرنك السويسري',
            CNY: 'اليوان الصيني',
            INR: 'الروبية الهندية',
            AED: 'درهم الإمارات',
            SAR: 'الريال السعودي',
            TRY: 'الليرة التركية',
            RUB: 'الروبل الروسي',
            BRL: 'الريال البرازيلي',
            KRW: 'وون كوري جنوبي'
        };
        
        // أيقونات العملات
        const currencyIcons = {
            USD: 'fa-dollar-sign',
            EUR: 'fa-euro-sign',
            GBP: 'fa-pound-sign',
            EGP: 'fa-money-bill',
            JPY: 'fa-yen-sign',
            AUD: 'fa-dollar-sign',
            CAD: 'fa-dollar-sign',
            CHF: 'fa-franc-sign',
            CNY: 'fa-yen-sign',
            INR: 'fa-rupee-sign',
            AED: 'fa-coins',
            SAR: 'fa-coins',
            TRY: 'fa-lira-sign',
            RUB: 'fa-ruble-sign',
            BRL: 'fa-money-bill',
            KRW: 'fa-won-sign'
        };
        
        // تحديث التاريخ الحالي
        function updateCurrentDate() {
            const now = new Date();
            const options = { 
                weekday: 'long', 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
            };
            currentDateEl.textContent = now.toLocaleDateString('ar-EG', options);
        }
        
        // جلب بيانات أسعار الصرف
        async function fetchExchangeRates() {
            try {
                const baseCurrency = baseCurrencySelect.value;
                const response = await fetch(`https://api.exchangerate-api.com/v4/latest/${baseCurrency}`);
                
                if (!response.ok) {
                    throw new Error('فشل في جلب البيانات');
                }
                
                const data = await response.json();
                return data;
            } catch (error) {
                console.error('حدث خطأ:', error);
                currencyContainer.innerHTML = `
                    <div class="error">
                        <i class="fas fa-exclamation-triangle"></i>
                        <p>حدث خطأ في جلب بيانات أسعار الصرف. يرجى المحاولة مرة أخرى لاحقًا.</p>
                    </div>
                `;
                return null;
            }
        }
        
        // عرض بيانات العملات
        function displayCurrencies(data) {
            if (!data) return;
            
            // تحديث وقت التحديث
            const updateDate = new Date(data.time_last_updated * 1000);
            lastUpdatedEl.textContent = updateDate.toLocaleString('ar-EG', {
                hour: '2-digit',
                minute: '2-digit',
                day: 'numeric',
                month: 'long'
            });
            
            const baseCurrency = baseCurrencySelect.value;
            const searchTerm = searchInput.value.toLowerCase();
            
            // تصفية العملات بناءً على البحث
            const filteredCurrencies = targetCurrencies.filter(currency => {
                const currencyName = currencyNames[currency] || currency;
                return currencyName.toLowerCase().includes(searchTerm) || 
                       currency.toLowerCase().includes(searchTerm);
            });
            
            // إنشاء بطاقات العملات
            currencyContainer.innerHTML = filteredCurrencies.map(currency => {
                if (!data.rates[currency]) return '';
                
                const rate = data.rates[currency];
                const currencyName = currencyNames[currency] || currency;
                const currencyIcon = currencyIcons[currency] || 'fa-coins';
                
                // توليد تغيير عشوائي للأغراض التوضيحية
                const change = (Math.random() - 0.5) / 10;
                const changeClass = change >= 0 ? 'change-up' : 'change-down';
                const changeIcon = change >= 0 ? 'fas fa-arrow-up' : 'fas fa-arrow-down';
                
                return `
                    <div class="currency-card">
                        <div class="currency-header">
                            <div class="currency-name">${currencyName} (${currency})</div>
                            <div class="currency-icon">
                                <i class="fas ${currencyIcon}"></i>
                            </div>
                        </div>
                        <div class="currency-value">${rate.toFixed(4)}</div>
                        <div class="currency-change ${changeClass}">
                            <i class="${changeIcon}"></i>
                            ${(Math.abs(change) * 100).toFixed(2)}%
                        </div>
                        <div class="last-update">
                            سعر الصرف مقابل ${currencyNames[baseCurrency] || baseCurrency}
                        </div>
                    </div>
                `;
            }).join('');
            
            // إذا لم توجد نتائج
            if (currencyContainer.innerHTML === '') {
                currencyContainer.innerHTML = `
                    <div class="error">
                        <i class="fas fa-search"></i>
                        <p>لم يتم العثور على عملات تطابق بحثك</p>
                    </div>
                `;
            }
        }
        
        // إدارة الإعدادات
        function setupSettings() {
            // فتح الإعدادات
            settingsBtn.addEventListener('click', () => {
                settingsModal.style.display = 'flex';
            });
            
            // إغلاق الإعدادات
            closeSettings.addEventListener('click', () => {
                settingsModal.style.display = 'none';
            });
            
            // اختيار اللغة
            languageOptions.forEach(option => {
                option.addEventListener('click', () => {
                    languageOptions.forEach(opt => opt.classList.remove('selected'));
                    option.classList.add('selected');
                });
            });
            
            // اختيار المظهر
            themeOptions.forEach(option => {
                option.addEventListener('click', () => {
                    themeOptions.forEach(opt => opt.classList.remove('selected'));
                    option.classList.add('selected');
                });
            });
            
            // حفظ الإعدادات
            saveSettings.addEventListener('click', () => {
                const selectedLang = document.querySelector('.language-option.selected').dataset.lang;
                const selectedTheme = document.querySelector('.theme-option.selected').dataset.theme;
                
                // تغيير المظهر
                document.body.className = '';
                document.body.classList.add(`theme-${selectedTheme}`);
                
                // تغيير اللغة (نظريًا - هذا يحتاج لتنفيذ حقيقي)
                alert(`تم اختيار اللغة: ${selectedLang} والمظهر: ${selectedTheme}`);
                
                // إغلاق النافذة
                settingsModal.style.display = 'none';
            });
        }
        
        // التهيئة
        async function init() {
            updateCurrentDate();
            setupSettings();
            
            // جلب البيانات وعرضها
            const data = await fetchExchangeRates();
            displayCurrencies(data);
            
            // تحديث البيانات كل 5 دقائق
            setInterval(async () => {
                const data = await fetchExchangeRates();
                displayCurrencies(data);
            }, 5 * 60 * 1000);
        }
        
        // مستمعات الأحداث
        searchInput.addEventListener('input', async () => {
            const data = await fetchExchangeRates();
            displayCurrencies(data);
        });
        
        baseCurrencySelect.addEventListener('change', async () => {
            currencyContainer.innerHTML = `
                <div class="loading">
                    <i class="fas fa-spinner fa-spin"></i> جاري تحديث البيانات...
                </div>
            `;
            const data = await fetchExchangeRates();
            displayCurrencies(data);
        });
        
        // بدء التطبيق
        init();
    </script>
</body>
</html>
